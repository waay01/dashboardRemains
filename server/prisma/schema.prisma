generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Product {
  id           Int               @id @default(autoincrement())
  tid          Int?
  name         String
  article      String?
  externalCode String?
  stock        Stock[]
  items        TransactionItem[]

  @@index([article])
  @@index([name])
  @@index([externalCode])
}

model Cell {
  address String            @id
  sector  String?
  stock   Stock[]
  items   TransactionItem[]

  @@index([sector])
}

model Stock {
  id          Int     @id @default(autoincrement())
  cellAddress String
  productId   Int
  quantity    Int     @default(0)
  cell        Cell    @relation(fields: [cellAddress], references: [address])
  product     Product @relation(fields: [productId], references: [id])

  @@unique([cellAddress, productId])
  @@index([cellAddress])
  @@index([productId])
}

model Transaction {
  id             Int               @id @default(autoincrement())
  type           String // 'incoming' | 'outgoing'
  documentNumber String
  driverName     String?
  counterparty   String?
  date           DateTime          @db.Date
  createdAt      DateTime          @default(now())
  userId         Int?
  user           User?             @relation(fields: [userId], references: [id])
  items          TransactionItem[]

  @@index([type])
  @@index([date])
  @@index([type, date])
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int
  cellAddress   String
  productId     Int
  quantity      Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  cell          Cell        @relation(fields: [cellAddress], references: [address])
  product       Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
}
